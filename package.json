{
  "type": "module",
  "name": "@phi-ag/ifc-guid",
  "version": "1.1.2",
  "license": "MIT",
  "description": "Convert IFC GUID",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phi-ag/ifc-guid.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ifc",
    "uuid",
    "guid"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:dev": "vitest",
    "test:coverage": "vitest --run --coverage src",
    "format": "prettier --write \"**/*.{js,ts,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,yml,yaml}\"",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "uuid": ">=10"
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@trivago/prettier-plugin-sort-imports": "5.2.2",
    "@vitest/coverage-v8": "3.1.4",
    "eslint": "9.29.0",
    "fast-check": "4.1.1",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.0",
    "vitest": "3.1.4"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
